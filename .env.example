# ===== إعدادات Trendora =====
# انسخ هذا الملف إلى ملف باسم .env ثم عدّل القيم

# المنفذ الذي يعمل عليه الموقع
PORT=3000

# كلمة مرور لوحة التحكم (غيّرها فوراً إلى كلمة قوية)
ADMIN_PASSWORD=trendora2026

# سر الجلسات (أي نص عشوائي طويل)
SESSION_SECRET=change-this-to-a-long-random-string

# رابط موقعك النهائي بعد ربط الدومين (يُستخدم في خريطة الموقع وروابط SEO)
SITE_URL=https://www.trendora.com

# ===== قاعدة البيانات (للنشر فقط) =====
# اتركه فارغاً محلياً ليعمل الموقع بملف JSON.
# عند النشر، ضع رابط MongoDB Atlas هنا لحفظ المقالات والصور بشكل دائم.
# مثال: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB=trendora

# ===== الذكاء الاصطناعي =====
# مفتاح OpenAI لتوليد المقالات (احصل عليه من https://platform.openai.com/api-keys)
OPENAI_API_KEY=
# الموديل المستخدم للتوليد
OPENAI_MODEL=gpt-4o-mini
