# ===== إعدادات Trendora =====
# انسخ هذا الملف إلى ملف باسم .env ثم عدّل القيم

# المنفذ الذي يعمل عليه الموقع
PORT=3000

# كلمة مرور لوحة التحكم (غيّرها فوراً إلى كلمة قوية)
ADMIN_PASSWORD=trendora2026

# سر الجلسات (أي نص عشوائي طويل)
SESSION_SECRET=change-this-to-a-long-random-string

# رابط موقعك النهائي بعد ربط الدومين (يُستخدم في خريطة الموقع وروابط SEO)
SITE_URL=https://trendora1.com

# ===== قاعدة البيانات =====
# الأولوية: Firebase Firestore ← MongoDB ← ملف JSON محلي
# اتركها كلها فارغة محلياً ليعمل الموقع بملف JSON بدون أي إعداد.

# --- الخيار المعتمد: Firebase Firestore (عبر الخادم) ---
# ضع محتوى ملف Service Account JSON بعد ترميزه Base64 في سطر واحد.
# (طريقة الحصول عليه والترميز موضّحة في README.md)
FIREBASE_SERVICE_ACCOUNT_B64=
# اسم حاوية التخزين للصور (من إعدادات مشروع Firebase)
FIREBASE_STORAGE_BUCKET=trendora-data.firebasestorage.app

# --- بديل: MongoDB Atlas ---
# مثال: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB=trendora

# ===== الذكاء الاصطناعي (اختياري — يمكن استخدام أي مزوّد أو كليهما) =====

# --- Google Gemini (مجاني) ---
# احصل على مفتاح مجاني من https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- OpenAI (مدفوع) ---
# احصل عليه من https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
